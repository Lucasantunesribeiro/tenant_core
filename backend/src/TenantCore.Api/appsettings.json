{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServer": "Server=localhost,1433;Database=tenant_core;User Id=sa;Password=Your_password123;TrustServerCertificate=true",
    "Redis": "localhost:6379"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Issuer": "tenant_core",
    "Audience": "tenant_core.web",
    "SigningKey": "tenant-core-development-signing-key-please-change",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Jobs": {
    "UsageSnapshotCron": "0 */10 * * * ?",
    "SubscriptionEnforcementCron": "0 */15 * * * ?",
    "CleanupCron": "0 0 2 * * ?"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4318/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}
